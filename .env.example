# Local admin password for the API
ADMIN_PASSWORD=admin123

# Firebase persistence settings
# Backend uses Firestore in project fdxx-13207 by default.
FIREBASE_PROJECT_ID=fdxx-13207

# Firebase service account JSON string for server persistence.
# Use the Vercel dashboard or local .env to set this.
FIREBASE_SERVICE_ACCOUNT={}

# Alternatively, set Firebase service account fields separately:
# FIREBASE_CLIENT_EMAIL=your-firebase-client-email
# FIREBASE_PRIVATE_KEY="your-firebase-private-key"

# Optional Vite public Firebase client config for frontend Firestore usage.
# These variables are safe to expose in the browser.
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=fdxx-13207.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=fdxx-13207
VITE_FIREBASE_STORAGE_BUCKET=fdxx-13207.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id
